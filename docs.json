{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FiveMesh Docs",
  "colors": {
    "primary": "#18181B",
    "light": "#FAFAFA",
    "dark": "#18181B"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicons/favicon.ico",
  "api": {
    "mdx": {
      "server": "https://api.fivemesh.io/v1",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "logo": {
    "light": "/logo/fivemesh-light.svg",
    "dark": "/logo/fivemesh-dark.svg",
    "href": "https://fivemesh.io"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "icon": "book-open",
        "pages": [
          "index",
          "quickstart",
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/workspaces",
              "dashboard/organizations",
              "dashboard/billing"
            ]
          },
          {
            "group": "FiveMesh CDN",
            "pages": ["cdn/setup", "cdn/object-browser", "cdn/settings"]
          },
          {
            "group": "FiveMesh Cache",
            "pages": ["cache/setup", "cache/operations"]
          },
          {
            "group": "FiveMesh Voice",
            "pages": ["voice/setup", "voice/operations"]
          },
          {
            "group": "Integrations",
            "pages": ["integrations/lb-scripts"]
          },
          {
            "group": "Account",
            "pages": ["account/servers", "account/api-keys"]
          },
          {
            "group": "Reference",
            "pages": ["reference/troubleshooting"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "pages": [
          "api-reference/introduction",
          "api-reference/authentication",
          {
            "group": "FiveMesh CDN",
            "pages": [
              "api-reference/cdn",
              "api-reference/cdn-endpoints/list-objects",
              "api-reference/cdn-endpoints/upload-object",
              "api-reference/cdn-endpoints/upload-base64-object",
              "api-reference/cdn-endpoints/bulk-upload-objects",
              "api-reference/cdn-endpoints/delete-object",
              "api-reference/cdn-endpoints/bulk-delete-objects",
              "api-reference/cdn-endpoints/create-upload-url",
              "api-reference/cdn-endpoints/upload-with-url"
            ]
          },
          {
            "group": "FiveMesh Cache",
            "pages": ["api-reference/cache"]
          },
          {
            "group": "FiveMesh Voice",
            "pages": ["api-reference/voice"]
          }
        ]
      },
      {
        "tab": "SDK",
        "icon": "code",
        "pages": [
          "sdk/introduction",
          {
            "group": "FiveM SDK",
            "pages": [
              "sdk/installation",
              "sdk/server-exports",
              "sdk/screenshots",
              "sdk/presigned-uploads",
              "sdk/troubleshooting"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://fivemesh.io",
          "icon": "globe"
        },
        {
          "anchor": "Dashboard",
          "href": "https://fivemesh.io/dashboard",
          "icon": "layout-dashboard"
        },
        {
          "anchor": "Status",
          "href": "https://status.fivemesh.io",
          "icon": "signal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/wBJamWETxr"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://fivemesh.io/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/FiveMesh",
      "x": "https://x.com/fivemesh_",
      "discord": "https://discord.gg/wBJamWETxr"
    }
  }
}
