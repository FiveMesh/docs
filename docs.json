{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FiveMesh Docs",
  "colors": {
    "primary": "#18181B",
    "light": "#FAFAFA",
    "dark": "#18181B"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon-fivemesh.svg",
  "logo": {
    "light": "/logo/fivemesh-light.svg",
    "dark": "/logo/fivemesh-dark.svg",
    "href": "https://fivemesh.io"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "icon": "book-open",
        "pages": [
          "index",
          "quickstart",
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/workspaces",
              "dashboard/organizations",
              "dashboard/billing"
            ]
          },
          {
            "group": "FiveMesh CDN",
            "pages": ["cdn/setup", "cdn/object-browser", "cdn/settings"]
          },
          {
            "group": "FiveMesh Cache",
            "pages": ["cache/setup", "cache/operations"]
          },
          {
            "group": "Integrations",
            "pages": ["integrations/lb-scripts"]
          },
          {
            "group": "Account",
            "pages": ["account/servers", "account/api-keys"]
          },
          {
            "group": "Reference",
            "pages": ["reference/troubleshooting"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "pages": [
          "api-reference/introduction",
          "api-reference/authentication",
          {
            "group": "Services",
            "pages": ["api-reference/cdn", "api-reference/cache"]
          }
        ]
      },
      {
        "tab": "SDK",
        "icon": "code",
        "pages": ["sdk/introduction"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://fivemesh.io",
          "icon": "globe"
        },
        {
          "anchor": "Dashboard",
          "href": "https://fivemesh.io/dashboard",
          "icon": "layout-dashboard"
        },
        {
          "anchor": "Status",
          "href": "https://status.fivemesh.io",
          "icon": "signal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/fivemesh"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://fivemesh.io/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/fivemesh"
    }
  }
}
