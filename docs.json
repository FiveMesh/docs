{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FiveMesh Docs",
  "colors": {
    "primary": "#0A0A0A",
    "light": "#18181B",
    "dark": "#FAFAFA"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Start",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Dashboard",
        "pages": [
          "dashboard/overview",
          "dashboard/workspaces",
          "dashboard/organizations",
          "dashboard/billing"
        ]
      },
      {
        "group": "FiveMesh CDN",
        "pages": [
          "cdn/setup",
          "cdn/object-browser",
          "cdn/settings"
        ]
      },
      {
        "group": "FiveMesh Cache",
        "pages": [
          "cache/setup",
          "cache/operations"
        ]
      },
      {
        "group": "Account",
        "pages": [
          "account/servers",
          "account/api-keys"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/troubleshooting"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://fivemesh.io",
          "icon": "globe"
        },
        {
          "anchor": "Dashboard",
          "href": "https://fivemesh.io/dashboard",
          "icon": "layout-dashboard"
        },
        {
          "anchor": "Status",
          "href": "https://status.fivemesh.io",
          "icon": "signal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/fivemesh"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://fivemesh.io/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/fivemesh"
    }
  }
}
